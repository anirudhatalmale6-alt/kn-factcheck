<%- include('partials/head') %>

<% if (!filtered) { %>
<section class="hero">
  <h1 class="hero-title"><%= site_name %></h1>
  <p class="hero-tagline"><%= tagline %></p>
  <div class="hero-cta">
    <a class="btn" href="<%= base %>/submit-tip">Submit a tip</a>
    <a class="btn ghost" href="<%= base %>/about">About the project</a>
    <a class="btn ghost" href="<%= base %>/standards">Editorial standards</a>
  </div>
</section>
<% } %>

<div class="row" style="justify-content:space-between;align-items:flex-end;margin-bottom:4px">
  <h2 style="margin:0"><%= filtered ? 'Fact-checks' : 'Latest fact-checks' %></h2>
  <form method="get" action="<%= base %>/" class="inline">
    <select name="cat" onchange="this.form.submit()" aria-label="Filter by verdict" style="width:auto;min-width:130px">
      <option value="">All verdicts</option>
      <% categories.forEach(function(c){ %><option value="<%= c.key %>" <%= cat===c.key?'selected':'' %>><%= c.label %></option><% }) %>
    </select>
    <select name="type" onchange="this.form.submit()" aria-label="Filter by source type" style="width:auto;min-width:130px">
      <option value="">All types</option>
      <% sourceTypes.forEach(function(t){ %><option value="<%= t.key %>" <%= type===t.key?'selected':'' %>><%= t.label %></option><% }) %>
    </select>
    <% if (cat || type) { %><a class="btn ghost small" href="<%= base %>/">Clear</a><% } %>
  </form>
</div>

<% if (!items.length) { %>
  <div class="empty">No published fact-checks<% if (cat||type) { %> match this filter<% } %> yet.<% if (user && can('submit')) { %> <a href="<%= base %>/admin/submit">Submit one &rarr;</a><% } %></div>
<% } else { %>
  <div class="grid">
    <% items.forEach(function(it){ %>
      <a class="fc-card" href="<%= base %>/fact-check/<%= it.slug %>">
        <div class="fc-top">
          <%- include('partials/badge', { cat: it.final_category }) %>
          <span class="tag"><%= SOURCE_TYPE_MAP[it.source_type] || it.source_type || 'website' %></span>
        </div>
        <div class="fc-summary" lang="<%= uiLang %>" dir="<%= uiDir %>"><%= it.public_summary %></div>
        <div class="fc-meta"><%= it.source_domain || 'direct submission' %> &middot; <%= (it.published_at||'').slice(0,10) %></div>
      </a>
    <% }) %>
  </div>
<% } %>
<%- include('partials/foot') %>
