<!doctype html>
<html lang="en" data-theme="<%= theme %>">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= title %> · <%= site_name %></title>
<% var _seo = (typeof seo !== 'undefined' && seo) ? seo : null; %>
<% if (_seo) { %>
<meta name="description" content="<%= _seo.description %>">
<meta property="og:title" content="<%= _seo.title || title %>">
<meta property="og:description" content="<%= _seo.description %>">
<meta property="og:type" content="<%= _seo.type || 'website' %>">
<meta property="og:site_name" content="<%= site_name %>">
<% if (_seo.url) { %><meta property="og:url" content="<%= _seo.url %>"><link rel="canonical" href="<%= _seo.url %>"><% } %>
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= _seo.title || title %>">
<meta name="twitter:description" content="<%= _seo.description %>">
<% } %>
<% if (typeof ldjson !== 'undefined' && ldjson) { %><script type="application/ld+json"><%- ldjson %></script><% } %>
<link rel="stylesheet" href="<%= base %>/static/style.css">
<style>:root{--accent:<%= accent %>;--accent-d:<%= accent %>}</style>
</head>
<body>
<header class="site">
  <div class="wrap">
    <a class="brand" href="<%= base %>/"><%= site_name %></a>
    <nav>
      <a href="<%= base %>/">Fact-checks</a>
      <a href="<%= base %>/standards">Standards</a>
      <% if (user) { %>
        <a href="<%= base %>/admin">Dashboard</a>
        <a href="<%= base %>/admin/submissions">All URLs</a>
        <% if (can('submit')) { %><a href="<%= base %>/admin/submit">Submit</a><% } %>
        <% if (can('policy')) { %><a href="<%= base %>/admin/policy">Policy</a><% } %>
        <% if (can('categories')) { %><a href="<%= base %>/admin/categories">Categories</a><% } %>
        <% if (can('source_types')) { %><a href="<%= base %>/admin/source-types">Types</a><% } %>
        <% if (can('users')) { %><a href="<%= base %>/admin/users">Users</a><% } %>
        <% if (can('settings')) { %><a href="<%= base %>/admin/settings">Settings</a><% } %>
        <a href="<%= base %>/admin/2fa">2FA</a>
        <form action="<%= base %>/admin/logout" method="post" style="display:inline">
          <button class="btn ghost small" type="submit"><%= user.name || user.username %> · Sign out</button>
        </form>
      <% } else { %>
        <a href="<%= base %>/submit-tip">Submit a tip</a>
        <a href="<%= base %>/admin/login">Staff sign in</a>
      <% } %>
    </nav>
  </div>
</header>
<main><div class="wrap">
