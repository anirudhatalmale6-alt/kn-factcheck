<!doctype html>
<html lang="en" data-theme="<%= theme %>">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&family=Noto+Nastaliq+Urdu:wght@400;600&family=Noto+Sans+Devanagari:wght@400;600&family=Noto+Sans+Gurmukhi:wght@400;600&display=swap" rel="stylesheet">
<% if (typeof alternates !== 'undefined' && alternates) { alternates.forEach(function(a){ %><link rel="alternate" hreflang="<%= a.code %>" href="<%= a.href %>"><% }); } %>
<title><%= title %> · <%= site_name %></title>
<% var _seo = (typeof seo !== 'undefined' && seo) ? seo : null; %>
<% if (_seo) { %>
<meta name="description" content="<%= _seo.description %>">
<meta property="og:title" content="<%= _seo.title || title %>">
<meta property="og:description" content="<%= _seo.description %>">
<meta property="og:type" content="<%= _seo.type || 'website' %>">
<meta property="og:site_name" content="<%= site_name %>">
<% if (_seo.url) { %><meta property="og:url" content="<%= _seo.url %>"><link rel="canonical" href="<%= _seo.url %>"><% } %>
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= _seo.title || title %>">
<meta name="twitter:description" content="<%= _seo.description %>">
<% } %>
<% if (typeof ldjson !== 'undefined' && ldjson) { %><script type="application/ld+json"><%- ldjson %></script><% } %>
<link rel="stylesheet" href="<%= base %>/static/style.css">
<style>:root{--accent:<%= accent %>;--accent-d:<%= accent %>}</style>
<script>
/* Apply the visitor's saved theme (or system) before paint - no flash. */
(function(){try{
  var saved=localStorage.getItem('kn-theme');           // 'light' | 'dark' | 'system' | null
  var d=document.documentElement;
  function sys(){return matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}
  if(saved==='light'||saved==='dark') d.setAttribute('data-theme',saved);
  else if(saved==='system') d.setAttribute('data-theme',sys());
  /* else: keep the server-rendered admin default */
}catch(e){}})();
</script>
</head>
<body>
<header class="site">
  <div class="wrap">
    <a class="brand" href="<%= base %>/"><% if (logo) { %><img src="<%= base %><%= logo %>" alt="<%= site_name %>" style="max-height:40px;max-width:220px;vertical-align:middle"><% } else { %><%= site_name %><% } %></a>
    <nav>
      <a href="<%= base %>/">Fact-checks</a>
      <a href="<%= base %>/about">About</a>
      <a href="<%= base %>/standards">Standards</a>
      <% if (user) { %>
        <a href="<%= base %>/admin">Dashboard</a>
        <a href="<%= base %>/admin/submissions">All URLs</a>
        <% if (can('submit')) { %><a href="<%= base %>/admin/submit">Submit</a><% } %>
        <% if (can('policy')) { %><a href="<%= base %>/admin/policy">Policy</a><% } %>
        <% if (can('categories')) { %><a href="<%= base %>/admin/categories">Categories</a><% } %>
        <% if (can('source_types')) { %><a href="<%= base %>/admin/source-types">Types</a><% } %>
        <% if (can('languages')) { %><a href="<%= base %>/admin/languages">Languages</a><% } %>
        <% if (can('users')) { %><a href="<%= base %>/admin/users">Users</a><% } %>
        <% if (can('settings')) { %><a href="<%= base %>/admin/settings">Settings</a><% } %>
        <a href="<%= base %>/admin/2fa">2FA</a>
        <form action="<%= base %>/admin/logout" method="post" style="display:inline">
          <button class="btn ghost small" type="submit"><%= user.name || user.username %> · Sign out</button>
        </form>
      <% } else { %>
        <a href="<%= base %>/submit-tip">Submit a tip</a>
        <a href="<%= base %>/admin/login">Staff sign in</a>
      <% } %>
      <button id="themeBtn" class="btn ghost small" type="button" title="Switch theme">Theme</button>
    </nav>
  </div>
</header>
<script>
(function(){
  var btn=document.getElementById('themeBtn'); if(!btn) return;
  var d=document.documentElement, order=['light','dark','system'];
  function sys(){return matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';}
  function apply(mode){
    d.setAttribute('data-theme', mode==='system'?sys():mode);
    btn.textContent = mode==='system' ? 'Theme: Auto' : (mode==='dark'?'Theme: Dark':'Theme: Light');
  }
  var mode = localStorage.getItem('kn-theme') || '<%= theme %>';   // fall back to admin default
  apply(mode);
  btn.addEventListener('click', function(){
    var cur = localStorage.getItem('kn-theme') || '<%= theme %>';
    var next = order[(order.indexOf(cur)+1) % order.length];
    localStorage.setItem('kn-theme', next); apply(next);
  });
  matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(){
    if((localStorage.getItem('kn-theme')||'')==='system') apply('system');
  });
})();
</script>
<main><div class="wrap">
