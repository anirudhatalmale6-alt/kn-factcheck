<%- include('partials/head') %>
<h1>Submit a tip</h1>
<% if (done) { %>
  <div class="ok">Thanks &mdash; your tip has been received and stored for our team to review. You don't need an account.</div>
  <p><a class="btn ghost" href="<%= base %>/submit-tip">Submit another</a> <a class="btn ghost" href="<%= base %>/">Back to fact-checks</a></p>
<% } else { %>
  <p class="sub">Seen a claim about Kashmir you'd like checked? Paste the link. No account needed &mdash; it goes straight to our team.</p>
  <% if (error) { %><div class="err"><%= error %></div><% } %>
  <form method="post" action="<%= base %>/submit-tip" style="max-width:620px">
    <label>Link (news article, Facebook/X post, video, etc.)</label>
    <input type="url" name="url" placeholder="https://..." value="<%= url %>" autofocus>
    <label>Anything we should know? <span class="hint">(optional)</span></label>
    <textarea name="note" placeholder="Why this seems worth checking..."></textarea>
    <div style="position:absolute;left:-9999px" aria-hidden="true"><label>Website</label><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
    <div style="margin-top:16px"><button class="btn" type="submit">Send tip</button></div>
  </form>
<% } %>
<%- include('partials/foot') %>
