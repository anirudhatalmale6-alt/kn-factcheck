<%- include('partials/head') %>
<h1>Submit for checking</h1>
<% if (done) { %>
  <div class="ok">Thanks &mdash; your submission has been received and added to our queue for an editor to review.</div>
  <p style="margin-top:18px"><a class="btn ghost" href="<%= base %>/submit-tip">Submit another</a> <a class="btn ghost" href="<%= base %>/">Back to fact-checks</a></p>
<% } else { %>
  <p class="sub">Seen a claim about Kashmir you'd like checked? Paste the link and it goes straight to our editorial team to review. No account needed.</p>
  <% if (error) { %><div class="err"><%= error %></div><% } %>
  <form method="post" action="<%= base %>/submit-tip" style="max-width:620px">
    <label>Link (news article, Facebook/X post, video, etc.)</label>
    <input type="url" name="url" placeholder="https://..." value="<%= url %>" autofocus>
    <label>Your name <span class="hint">(optional &mdash; shown to our editors so we know who sent it)</span></label>
    <input type="text" name="submitter_name" placeholder="Name or handle">
    <label>Anything we should know? <span class="hint">(optional)</span></label>
    <textarea name="note" placeholder="Why this seems worth checking..."></textarea>
    <div style="position:absolute;left:-9999px" aria-hidden="true"><label>Website</label><input type="text" name="website" tabindex="-1" autocomplete="off"></div>
    <div style="margin-top:16px"><button class="btn" type="submit">Send for checking</button></div>
  </form>
<% } %>
<%- include('partials/foot') %>
