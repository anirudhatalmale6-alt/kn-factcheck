<%- include('partials/head') %>
<p><a href="<%= base %>/admin">&larr; Queue</a></p>
<div class="row" style="justify-content:space-between">
  <h1>Review #<%= sub.id %></h1>
  <span class="meta"><%= sub.status %></span>
</div>
<% if (typeof error !== 'undefined' && error) { %><div class="err"><%= error %></div><% } %>

<div class="card">
  <h3><%= sub.raw_title || '(no title)' %></h3>
  <div class="kv">
    <% if (sub.url) { %><div class="k">URL</div><div><a href="<%= sub.url %>" target="_blank" rel="nofollow noopener"><%= sub.url %></a></div><% } %>
    <div class="k">Source</div><div><%= sub.source_domain %></div>
    <div class="k">Type</div><div><span class="tag"><%= SOURCE_TYPE_MAP[sub.source_type] || sub.source_type || 'website' %></span></div>
    <div class="k">Submitted by</div><div><%= typeof submitterLabel !== 'undefined' && submitterLabel ? submitterLabel : (sub.submitter_name ? sub.submitter_name + ' (public tip)' : 'Anonymous') %></div>
    <% if (sub.raw_author) { %><div class="k">Author</div><div><%= sub.raw_author %></div><% } %>
    <% if (sub.archive_url) { %><div class="k">Archived</div><div><a href="<%= sub.archive_url %>" target="_blank" rel="noopener">Wayback copy &rarr;</a></div><% } %>
    <% if (sub.submitter_note) { %><div class="k">Tip note</div><div><%= sub.submitter_note %></div><% } %>
  </div>

  <% if (sub.file_path) { %>
    <div style="margin-top:10px">
      <% if (sub.source_type==='image') { %>
        <img src="<%= base %><%= sub.file_path %>" alt="submitted image" style="max-width:100%;border-radius:10px;border:1px solid var(--line)">
      <% } else if (sub.source_type==='video') { %>
        <video src="<%= base %><%= sub.file_path %>" controls style="max-width:100%;border-radius:10px"></video>
      <% } else if (sub.source_type==='audio') { %>
        <audio src="<%= base %><%= sub.file_path %>" controls style="width:100%"></audio>
      <% } else { %>
        <a class="btn ghost small" href="<%= base %><%= sub.file_path %>" target="_blank">Open file &rarr;</a>
      <% } %>
    </div>
  <% } %>

  <% if (sub.raw_text) { %>
    <details style="margin-top:10px" <%= sub.content_kind==='text' ? 'open' : '' %>>
      <summary class="meta"><%= sub.content_kind==='text' ? 'Submitted text' : (sub.file_path ? 'Description / note' : 'Scraped text excerpt') %></summary>
      <div class="excerpt"><%= (sub.raw_text||'').slice(0,4000) %></div>
    </details>
  <% } %>
</div>

<h2>AI assessment</h2>
<div class="card">
  <% if (!ai) { %>
    <div class="notice">Not analysed yet. Run the AI check against your editorial policy when you're ready.</div>
    <form method="post" action="<%= base %>/admin/analyse/<%= sub.id %>">
      <button class="btn" type="submit">Analyse now</button>
    </form>
  <% } else { %>
    <% if (ai.model_used === 'stub') { %><div class="notice warn">Placeholder assessment (no API key yet).</div><% } %>
    <div class="row">
      <%- include('partials/badge', { cat: ai.suggested_category }) %>
      <span class="conf">confidence <%= ai.confidence != null ? (ai.confidence*100).toFixed(0)+'%' : 'n/a' %></span>
      <span class="conf"><%= ai.model_used || '' %></span>
    </div>
    <% if (claims && claims.length) { %>
      <label style="margin-top:14px">Extracted claims</label>
      <ul class="claims"><% claims.forEach(function(c){ %><li><%= c %></li><% }) %></ul>
    <% } %>
    <label style="margin-top:14px">Reasoning</label>
    <p style="margin:4px 0 0"><%= ai.reasoning %></p>
    <form method="post" action="<%= base %>/admin/analyse/<%= sub.id %>" style="margin-top:10px">
      <button class="btn ghost small" type="submit">Re-run analysis</button>
    </form>
  <% } %>
</div>

<h2>Editor decision</h2>
<form method="post" action="<%= base %>/admin/review/<%= sub.id %>">
  <div class="split">
    <div>
      <label>Final verdict category</label>
      <select name="final_category">
        <% var curCat = review ? review.final_category : (ai ? ai.suggested_category : (CATEGORIES[0]||'')); %>
        <% CATEGORIES.forEach(function(c){ %>
          <option value="<%= c %>" <%= curCat===c?'selected':'' %>><%= CATEGORY_META[c].label %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>Source type</label>
      <select name="source_type">
        <% sourceTypes.forEach(function(t){ %>
          <option value="<%= t.key %>" <%= (sub.source_type||'website')===t.key?'selected':'' %>><%= t.label %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="hint" style="margin-top:4px">The AI suggestion is a starting point &mdash; the published verdict is yours.</div>

  <label>Public summary <span class="hint">(shown to readers &mdash; 1&ndash;2 neutral sentences, no full reprint)</span></label>
  <textarea name="public_summary"><%= review ? review.public_summary : (ai ? ai.public_summary : '') %></textarea>

  <label>Editor's note <span class="hint">(optional, internal-to-public context)</span></label>
  <textarea name="editor_notes"><%= review ? review.editor_notes : '' %></textarea>

  <div class="row" style="margin-top:18px">
    <button class="btn" type="submit" name="action" value="publish"><%= sub.status === 'published' ? 'Update published' : 'Publish' %></button>
    <button class="btn danger" type="submit" name="action" value="reject" formnovalidate>Reject</button>
    <% if (review && sub.status === 'published') { %>
      <a class="btn ghost" href="<%= base %>/fact-check/<%= review.slug %>" target="_blank">View live &rarr;</a>
    <% } %>
  </div>
</form>

<% if (review && enabledLanguages && enabledLanguages.length > 1) { %>
  <h2>Translations</h2>
  <div class="card">
    <p class="hint" style="margin-top:0">Reader-facing text is auto-translated into your enabled languages when you publish. Re-run it here if you edit the summary or add a language.</p>
    <form method="post" action="<%= base %>/admin/translate/<%= review.id %>">
      <button class="btn ghost small" type="submit">Translate / re-translate</button>
      <a class="btn ghost small" href="<%= base %>/admin/languages">Manage languages</a>
    </form>
  </div>
<% } %>
<%- include('partials/foot') %>
